# Configurações do Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# Configurações da Aplicação
NODE_ENV=development
PORT=5000
UPLOADS_DIR=./uploads
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001
# Em produção single-service (frontend + API no mesmo domínio), pode deixar FRONTEND_ORIGINS vazio.

# Chave secreta para JWT
JWT_SECRET=your_secret_key_here

# Bootstrap de admin padrão (obrigatório para criação automática do primeiro admin)
DEFAULT_ADMIN_EMAIL=admin@reconectare.com.br
DEFAULT_ADMIN_PASSWORD=your_strong_admin_password
DEFAULT_ADMIN_NAME=Administrador Reconectare
DEFAULT_ADMIN_PHONE=5511999999999
DEFAULT_ADMIN_CPF=99999999999
