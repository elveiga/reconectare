# ==========================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ==========================================

# Copie este arquivo para .env e preencha com suas credenciais

# Host do banco de dados
DB_HOST=localhost

# Usuário do MySQL
DB_USER=root

# Senha do MySQL
DB_PASSWORD=

# Nome do banco de dados
DB_NAME=reconectarehtml

# Porta do MySQL (padrão: 3306)
DB_PORT=3306

# ==========================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ==========================================

# Porta do servidor (se usar Express)
PORT=3001

# Ambiente (development, production)
NODE_ENV=development

# Chave secreta para JWT (gere uma aleatória para produção)
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao

# Tempo de expiração do token (exemplo: 24h, 7d, 30d)
JWT_EXPIRES_IN=24h
